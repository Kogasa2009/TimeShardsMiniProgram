/* ===========================
 * 首页样式
 * 轮播图 + 公告列表
 * =========================== */

/* 页面底部留白 */
.index-container { padding-bottom: 20rpx; }

/* ---- 轮播图 ---- */
.banner-swiper {
  width: 100%;
  height: 360rpx;                                    /* 轮播图高度 */
}
.banner-image {
  width: 100%;
  height: 100%;
}
/* 轮播图占位——无数据时的灰色区域 */
.banner-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: #1a1a2e;
  color: #666;
  font-size: 28rpx;
}

/* ---- 区域头部 ---- */
.section-header {
  display: flex;
  justify-content: space-between;                    /* 标题左，"更多"右 */
  align-items: center;
  padding: 30rpx 30rpx 16rpx;
}
.section-title {
  font-size: 32rpx;
  color: #e6b800;                                    /* 金色标题 */
  font-weight: bold;
}
.section-more {
  font-size: 26rpx;
  color: #888;                                       /* 灰色链接 */
}

/* ---- 公告条目 ---- */
.news-item {
  display: flex;                                     /* 封面左 + 信息右 */
  margin: 0 30rpx 20rpx;
  background: rgba(255,255,255,0.05);                /* 半透明白色底 */
  border-radius: 12rpx;
  overflow: hidden;
}
.news-cover {
  width: 160rpx;
  height: 120rpx;
  flex-shrink: 0;                                    /* 不压缩 */
}
.news-info {
  flex: 1;                                           /* 占满剩余空间 */
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;                            /* 纵向排列 */
  justify-content: space-between;                    /* 上下两端对齐 */
}
.news-title {
  font-size: 28rpx; color: #fff;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; /* 单行截断 */
}
.news-summary {
  font-size: 22rpx; color: #999;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.news-time {
  font-size: 20rpx; color: #666;
}
/* 空状态 */
.news-empty {
  text-align: center; padding: 40rpx; color: #666; font-size: 26rpx;
}

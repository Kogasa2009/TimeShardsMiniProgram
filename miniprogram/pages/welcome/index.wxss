/* ===========================
 * 欢迎页样式
 * 全屏深色渐变背景 + 居中品牌内容 + 淡入上升入场动画
 * =========================== */

/* 全屏容器——固定定位 + flex 居中 */
.welcome-container {
  width: 100vw;                                      /* 视口宽度 */
  height: 100vh;                                     /* 视口高度 */
  background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%); /* 135° 三层深色渐变 */
  display: flex;
  align-items: center;                               /* 垂直居中 */
  justify-content: center;                           /* 水平居中 */
  overflow: hidden;                                  /* 隐藏溢出 */
  position: relative;                                /* 相对定位——为遮罩层提供定位基准 */
}

/* 遮罩层——中心光晕增加氛围 */
.welcome-overlay {
  position: absolute;                                /* 绝对定位覆盖全屏 */
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at center, rgba(230,184,0,0.08) 0%, transparent 70%); /* 椭圆径向渐变——中心金色光晕 */
}

/* 内容容器——纵向排列，初始隐藏（配合入场动画） */
.welcome-content {
  display: flex;
  flex-direction: column;                            /* 纵向排列：logo → 标题 → 副标题 → 按钮 */
  align-items: center;                               /* 水平居中 */
  opacity: 0;                                        /* 初始完全透明 */
  transform: translateY(30rpx);                      /* 初始向下偏移 30rpx */
  transition: all 0.6s ease-out;                     /* 0.6 秒缓出过渡 */
}

/* 入场动画触发——两种类名兼容 */
.welcome-content.fade-in-up, .ready .welcome-content {
  opacity: 1;                                        /* 完全不透明 */
  transform: translateY(0);                          /* 回到原位 */
}

/* Logo 图片 */
.welcome-logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

/* 应用标题——金色大字 */
.welcome-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #e6b800;                                    /* 金色 */
  letter-spacing: 6rpx;                              /* 字间距加宽 */
}

/* 副标题/口号 */
.welcome-subtitle {
  font-size: 28rpx;
  color: #aaa;                                       /* 浅灰色 */
  margin-top: 16rpx;
  margin-bottom: 80rpx;                              /* 与按钮拉开距离 */
}

/* 进入按钮——金橙渐变胶囊形 */
.welcome-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;                                /* 行高 = 高度实现文字垂直居中 */
  background: linear-gradient(135deg, #e6b800, #ffd700); /* 金→亮金 135° 渐变 */
  color: #1a1a2e;                                    /* 深色文字 */
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;                              /* 半高圆角 → 胶囊形 */
  text-align: center;
  border: none;                                      /* 去除默认边框 */
}

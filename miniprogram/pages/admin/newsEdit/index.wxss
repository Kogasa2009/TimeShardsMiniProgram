/* ===========================
 * 管理员公告编辑页样式
 * 表单卡片 + 封面/多图上传 + 固定底部保存按钮
 * =========================== */

/* 页面布局——底部留白 */
.page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* ---- 表单标题 ---- */
.form-title {
  padding: 20rpx 0;
}
.form-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* ---- 表单卡片 ---- */
.form {
  padding: 20rpx;
}
/* 表单行：横向排列，底部分割线 */
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #222;
}
/* 纵向布局（用于 textarea） */
.form-row-col {
  flex-direction: column;
  align-items: flex-start;
}
.form-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #aaa;
  flex-shrink: 0;
}
.form-row-col .form-label {
  margin-bottom: 12rpx;
}
.form-input {
  flex: 1;
  font-size: 26rpx;
  color: #e0e0e0;
}
/* 正文多行文本框——较高最小高度 */
.form-textarea {
  width: 100%;
  min-height: 400rpx;
  font-size: 26rpx;
  color: #e0e0e0;
  background: #12121f;
  border-radius: 8rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* ---- 图片上传区域 ---- */
.image-section {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #1a1a2e;
  border-radius: 12rpx;
}
.section-label {
  font-size: 26rpx;
  color: #aaa;
  display: block;
  margin-bottom: 16rpx;
}
.image-upload {
  display: flex;
}
/* 正文多图网格——flex wrap 自动换行 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 上传入口 */
.upload-btn {
  width: 180rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #12121f;
  border: 2rpx dashed #2a2a4a;
  border-radius: 12rpx;
}
/* 小号上传入口（用于多图网格中的"添加"按钮） */
.upload-btn-sm {
  width: 140rpx;
  height: 140rpx;
}
.upload-icon {
  font-size: 48rpx;
  color: #888;
}

/* 图片预览区域 */
.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
/* 小号预览（用于多图网格） */
.image-preview-sm {
  width: 140rpx;
  height: 140rpx;
}
.image-preview image,
.image-preview-sm image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

/* 红色删除按钮——绝对定位在右上角圆形 */
.remove-img {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4444;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

/* ---- 固定底部保存按钮 ---- */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, #0f0f1a 40%);
}
.save-bar .btn-primary {
  display: block;
}

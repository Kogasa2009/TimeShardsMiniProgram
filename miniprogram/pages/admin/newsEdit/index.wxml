
<view class="page">
  
  <view class="form-title">
    <text>{{ editing ? '编辑公告' : '发布公告' }}</text>
  </view>

  
  <view class="form card">
    
    <view class="form-row">
      <text class="form-label">标题 *</text>
      <input class="form-input" placeholder="公告标题" placeholder-style="color:#555" value="{{ title }}" bindinput="onInput" data-field="title" />
    </view>
    
    <view class="form-row">
      <text class="form-label">摘要</text>
      <input class="form-input" placeholder="简短摘要" placeholder-style="color:#555" value="{{ summary }}" bindinput="onInput" data-field="summary" />
    </view>
    
    <view class="form-row form-row-col">
      <text class="form-label">正文</text>
      <textarea class="form-textarea" placeholder="公告正文内容" placeholder-style="color:#555" value="{{ content }}" bindinput="onInput" data-field="content" auto-height maxlength="-1" />
    </view>
  </view>

  
  <view class="image-section">
    <text class="section-label">封面图片</text>
    <view class="image-upload">
      
      <block wx:if="{{ coverList.length > 0 }}">
        <view class="image-preview">
          <image src="{{ coverList[0] }}" mode="aspectFill" bindtap="previewImage" data-src="{{ coverList[0] }}" />
          <text class="remove-img" bindtap="removeCover">✕</text>
        </view>
      </block>
      
      <view class="upload-btn" bindtap="chooseCover" wx:else>
        <text class="upload-icon">＋</text>
        <text class="text-muted">点击上传</text>
      </view>
    </view>
  </view>

  
  <view class="image-section">
    <text class="section-label">正文图片（可多选）</text>
    <view class="image-grid">
      
      <block wx:for="{{ imageList }}" wx:key="index">
        <view class="image-preview image-preview-sm">
          <image src="{{ item }}" mode="aspectFill" bindtap="previewImage" data-src="{{ item }}" />
          <text class="remove-img" bindtap="removeImage" data-index="{{ index }}">✕</text>
        </view>
      </block>
      
      <view class="upload-btn upload-btn-sm" bindtap="chooseImages">
        <text class="upload-icon">＋</text>
      </view>
    </view>
  </view>

  
  <view class="save-bar">
    
    <view class="btn-primary" bindtap="saveNews">{{ uploading ? '上传中...' : '上传公告' }}</view>
  </view>
</view>

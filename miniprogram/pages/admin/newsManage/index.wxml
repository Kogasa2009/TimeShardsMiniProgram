
<view class="page">
  
  <view class="admin-header">
    <text class="admin-title">公告管理</text>
    <view class="btn-primary btn-small" bindtap="addNews">＋ 发布公告</view>
  </view>

  
  <view class="loading-view" wx:if="{{ loading }}">
    <text class="text-muted">加载中...</text>
  </view>

  
  <view class="news-list" wx:else>
    <block wx:for="{{ newsList }}" wx:key="_id">
      
      <view class="news-item">
        
        <image src="{{ item.coverUrl }}" class="news-thumb" mode="aspectFill" wx:if="{{ item.coverUrl }}" />
        <view class="news-info">
          <text class="news-title">{{ item.title }}</text>               
          <text class="text-muted news-summary">{{ item.summary }}</text> 
          <text class="text-muted" style="font-size:22rpx;">{{ item.createTime }}</text> 
        </view>
        
        <view class="news-actions">
          <view class="btn-edit" bindtap="editNews" data-id="{{ item._id }}">编辑</view>
          <view class="btn-delete" bindtap="deleteNews" data-id="{{ item._id }}">删除</view>
        </view>
      </view>
    </block>
    
    <view class="empty-view" wx:if="{{ newsList.length === 0 && !loading }}">
      <text>暂无公告</text>
    </view>
  </view>
</view>

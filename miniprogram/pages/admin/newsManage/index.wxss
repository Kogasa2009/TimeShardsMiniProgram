/* ===========================
 * 管理员公告管理页样式
 * 页面头部 + 公告列表
 * =========================== */

/* 页面内边距 */
.page {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* ---- 页面头部 ---- */
.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0 20rpx;
}
.admin-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* ---- 公告列表（纵向排列） ---- */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 单条公告：缩略图 + 信息 + 操作按钮 */
.news-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #1a1a2e;
  border-radius: 12rpx;
  border: 1px solid #2a2a4a;
}
/* 封面缩略图——固定大小 */
.news-thumb {
  width: 100rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;                                   /* 不被压缩 */
}
/* 公告信息：标题 + 摘要 + 时间 */
.news-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;                                 /* 配合子元素截断 */
}
.news-title {
  font-size: 28rpx;
  color: #e0e0e0;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;                          /* 超长显示省略号 */
  white-space: nowrap;                              /* 单行不换行 */
}
.news-summary {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 操作按钮区 */
.news-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;                                   /* 不被压缩，始终可见 */
}
/* 编辑/删除按钮共用尺寸 */
.btn-edit, .btn-delete {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}
.btn-edit {
  background: #2a2a4a;
  color: #e6b800;
}
.btn-delete {
  background: rgba(255, 68, 68, 0.15);
  color: #ff4444;
}

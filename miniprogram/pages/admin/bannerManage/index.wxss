/* ===========================
 * 管理员轮播图管理页样式
 * 页面头部 + 轮播图列表 + 排序/删除操作
 * =========================== */

/* 页面容器——深色背景，最小高度撑满 */
.banner-manage {
  padding: 20rpx;
  min-height: 100vh;
  background: #0f0f1a;
}

/* ---- 页面头部：标题 + 新增按钮 ---- */
.header-bar {
  display: flex;
  justify-content: space-between;                   /* 标题左、按钮右 */
  align-items: center;
  margin-bottom: 20rpx;
}
.header-title {
  font-size: 30rpx;
  color: #e6b800;                                   /* 金色标题 */
}
.add-btn {
  width: 140rpx;
  height: 60rpx;
  line-height: 60rpx;                               /* 垂直居中 */
  font-size: 24rpx;
  background: #e6b800;                              /* 金色背景 */
  color: #1a1a2e;                                   /* 深色文字 */
  border-radius: 8rpx;
  border: none;                                     /* 去除 button 默认边框 */
}

/* ---- 轮播图条目：缩略图 + 操作按钮 ---- */
.banner-item {
  display: flex;
  background: rgba(255, 255, 255, 0.05);            /* 半透明白色背景 */
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}
/* 缩略图——固定大小 */
.banner-thumb {
  width: 160rpx;
  height: 100rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
/* 右侧信息区 */
.banner-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;                   /* 排序值在上，按钮在下 */
}
.banner-order {
  font-size: 26rpx;
  color: #aaa;
}
/* 操作按钮行 */
.banner-actions {
  display: flex;
  gap: 12rpx;
}
/* 操作按钮通用样式 */
.action-btn {
  width: 80rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.1);             /* 半透明白色 */
  color: #fff;
  border-radius: 6rpx;
  border: none;
  text-align: center;
  padding: 0;                                       /* 去除 button 默认内边距 */
}
/* 删除按钮——红色警示 */
.action-btn.danger {
  background: rgba(255, 80, 80, 0.3);
  color: #ff5050;
}

/* ---- 空状态 ---- */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #666;
  font-size: 26rpx;
}

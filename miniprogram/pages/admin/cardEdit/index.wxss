/* ===========================
 * 管理员卡牌编辑页样式
 * 表单卡片 + 图片上传 + 固定底部保存按钮
 * =========================== */

/* 页面布局——底部留白防止被保存按钮遮挡 */
.page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* ---- 表单标题 ---- */
.form-title {
  padding: 20rpx 0;
}
.form-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* ---- 表单卡片 ---- */
.form {
  padding: 20rpx;
}

/* 表单行：标签 + 输入/选择，横向排列 */
.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #222;                    /* 行间分割线 */
}
/* 纵向布局的表单行（用于 textarea 多行文本） */
.form-row-col {
  flex-direction: column;
  align-items: flex-start;
}

/* 表单标签——固定宽度 */
.form-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #aaa;
  flex-shrink: 0;                                   /* 不被压缩 */
}
/* 纵向布局时标签下方需要间距 */
.form-row-col .form-label {
  margin-bottom: 12rpx;
}

/* 输入框——占满剩余宽度 */
.form-input {
  flex: 1;
  font-size: 26rpx;
  color: #e0e0e0;
}

/* 多行文本框——全宽、深色背景 */
.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 26rpx;
  color: #e0e0e0;
  background: #12121f;
  border-radius: 8rpx;
  padding: 16rpx;
}

/* picker 选择器当前值——金色高亮 */
.picker-value {
  color: #e6b800;
  font-size: 26rpx;
}

/* ---- 图片上传区域 ---- */
.image-section {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #1a1a2e;
  border-radius: 12rpx;
}
.section-label {
  font-size: 26rpx;
  color: #aaa;
  display: block;
  margin-bottom: 16rpx;
}
.image-upload {
  display: flex;
}

/* 上传入口：虚线框 + 加号图标，居中 */
.upload-btn {
  width: 180rpx;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #12121f;
  border: 2rpx dashed #2a2a4a;                      /* 虚线边框 */
  border-radius: 12rpx;
}
.upload-icon {
  font-size: 48rpx;
  color: #888;
}

/* 图片预览区——相对定位，容纳右上角删除按钮 */
.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.image-preview image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

/* 红色删除按钮——绝对定位在右上角，圆形 */
.remove-img {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4444;
  color: #fff;
  border-radius: 50%;                               /* 正圆形 */
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

/* ---- 固定底部保存按钮 ---- */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); /* 适配底部安全区 */
  background: linear-gradient(transparent, #0f0f1a 40%);     /* 底部渐变遮罩 */
}
.save-bar .btn-primary {
  display: block;                                   /* 全宽按钮 */
}

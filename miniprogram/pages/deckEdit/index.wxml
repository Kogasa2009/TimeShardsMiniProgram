
<view class="page">
  
  <view class="deck-config card">
    <view class="config-row">
      <text class="config-label">套牌名称</text>
      
      <input class="config-input"
        placeholder="输入套牌名称"
        placeholder-style="color:#555"
        value="{{ deckName }}"
        bindinput="onDeckNameInput" />
    </view>
    <view class="config-row">
      <text class="config-label">阵营</text>
      
      <picker mode="selector" range="{{ factions }}" value="{{ selectedFaction }}" bindchange="onFactionChange">
        <view class="picker-value">{{ factions[selectedFaction] }}</view>
      </picker>
    </view>
  </view>

  
  <view class="search-bar">
    <view class="search-input-box">
      <text class="search-icon">🔍</text>
      <input class="search-input"
        placeholder="搜索卡牌名称..."
        placeholder-style="color:#666"
        value="{{ searchKey }}"
        bindinput="onSearchInput" />
    </view>
  </view>

  
  <view class="columns">
    
    <view class="col-left">
      <text class="col-title">卡牌库 ({{ filteredCards.length }})</text>
      <scroll-view class="card-scroll" scroll-y="true">
        
        <view class="loading-view" wx:if="{{ loading }}">
          <text class="text-muted">加载中...</text>
        </view>
        
        <block wx:for="{{ filteredCards }}" wx:key="_id">
          <view class="mini-card card-touch" bindtap="viewCardDetail" data-id="{{ item._id }}">
            <text class="mini-card-cost">{{ item.cost }}</text>        
            <text class="mini-card-name">{{ item.name }}</text>        
            <text class="mini-card-faction {{ item.faction === '中立' ? 'faction-neutral' : '' }}">{{ item.faction }}</text> 
            
            <text class="mini-card-rarity rarity-{{ item.rarity === '纸' ? 'paper' : item.rarity === '锡' ? 'tin' : item.rarity === '铂' ? 'platinum' : 'crystal' }}">{{ item.rarity }}</text>
          </view>
        </block>
      </scroll-view>
    </view>

    
    <view class="col-right">
      <view class="col-title-row">
        <text class="col-title">卡组 ({{ totalCards }}/40)</text> 
        <text class="clear-btn" bindtap="clearDeck">清空</text>     
      </view>
      <scroll-view class="card-scroll" scroll-y="true">
        
        <block wx:for="{{ deckCardGroups }}" wx:key="card.name">
          <view class="mini-card mini-card-deck card-touch {{ coverUrl === item.card.imageUrl && item.card.imageUrl ? 'is-cover' : '' }}"
            bindtap="setCover" data-name="{{ item.card.name }}">
            <text class="mini-card-cost">{{ item.card.cost }}</text>  
            <text class="mini-card-name">{{ item.card.name }}</text>  
            <text class="mini-card-cover-icon" wx:if="{{ coverUrl === item.card.imageUrl && item.card.imageUrl }}">★</text> 
            <text class="mini-card-rarity">×{{ item.count }}</text>   
            <text class="remove-btn" catchtap="removeFromDeck" data-name="{{ item.card.name }}">✕</text> 
          </view>
        </block>
        
        <view class="empty-view" wx:if="{{ deckCards.length === 0 }}">
          <text class="text-muted" style="font-size:24rpx;">点击卡牌添加到卡组</text>
        </view>
      </scroll-view>
    </view>
  </view>

  
  <view class="bottom-bar">
    <view class="rule-text text-muted">规则: 纸卡≤4 · 锡卡≤3 · 铂卡≤2 · 晶卡≤1 · 恰好40张</view>
    <view class="bottom-btns">
      <view class="btn-secondary btn-small" bindtap="showImportPanel">导入代码</view>
      <view class="btn-primary btn-small {{ totalCards === 40 ? '' : 'btn-disabled' }}" bindtap="saveDeck">
        保存 ({{ totalCards }}/40)
      </view>
    </view>
  </view>

  
  <view class="import-mask" wx:if="{{ showImport }}">
    <view class="import-panel">
      <text class="import-title">导入套牌代码</text>
      <textarea class="import-textarea"
        placeholder="在此粘贴套牌代码..."
        placeholder-style="color:#555"
        value="{{ importCode }}"
        bindinput="onImportInput"
        auto-height maxlength="-1" />
      <view class="import-btns">
        <view class="btn-secondary btn-small" bindtap="hideImportPanel">取消</view>
        <view class="btn-primary btn-small" bindtap="confirmImport">确认导入</view>
      </view>
    </view>
  </view>
</view>

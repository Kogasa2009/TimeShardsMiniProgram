/* ===========================
 * 登录页样式
 * 全屏深色渐变 + 居中卡片 + 昵称输入 + 进入按钮
 * =========================== */

/* 全屏容器——flex 居中 */
.login-container {
  width: 100vw;                                      /* 视口宽度 */
  min-height: 100vh;                                 /* 最小高度撑满屏幕 */
  background: linear-gradient(180deg, #0f0f1a, #1a1a2e); /* 180° 自上而下深色渐变 */
  display: flex;
  align-items: center;                               /* 垂直居中 */
  justify-content: center;                           /* 水平居中 */
}

/* 登录卡片——半透明深色面板 */
.login-card {
  width: 600rpx;                                     /* 固定宽度 */
  padding: 60rpx 40rpx;                              /* 大内边距 */
  background: rgba(255,255,255,0.05);                /* 半透明白色背景 */
  border-radius: 24rpx;                              /* 大圆角 */
  display: flex;
  flex-direction: column;                            /* 纵向排列 */
  align-items: center;                               /* 水平居中 */
  border: 1rpx solid rgba(230,184,0,0.15);           /* 金色半透明细边框 */
}

/* Logo 图片 */
.login-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

/* 登录标题 */
.login-title {
  font-size: 40rpx;
  color: #e6b800;                                    /* 金色 */
  font-weight: bold;
}

/* 描述文字 */
.login-desc {
  font-size: 26rpx;
  color: #888;
  margin: 16rpx 0 40rpx;                             /* 上下间距 */
}

/* 头像选择按钮——虚线圆形 */
.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin-bottom: 30rpx;
  background: transparent;                           /* 透明背景 */
  border: 2rpx dashed rgba(230,184,0,0.3);           /* 金色虚线边框 */
  border-radius: 50%;                                /* 圆形 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* 去除微信 button 默认伪元素样式 */
.avatar-btn::after { border: none; }

/* 头像预览图 */
.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;                                /* 圆形裁剪 */
}

/* 头像提示文字——绝对定位于底部 */
.avatar-hint {
  font-size: 20rpx;
  color: #666;
  position: absolute;
  bottom: 24rpx;
}

/* 昵称输入框——深色半透明背景 + 居中文字 */
.nickname-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255,255,255,0.08);                /* 半透明白色背景 */
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;                            /* 边框盒模型 */
  font-size: 28rpx;
  color: #fff;
  text-align: center;                                /* 文字居中 */
  margin-bottom: 40rpx;
}

/* 进入按钮——金橙渐变胶囊形 */
.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #e6b800, #ffd700);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  text-align: center;
  border: none;
}

/* 禁用态——灰色不可点击 */
.login-btn[disabled] {
  background: #444;
  color: #888;
}

/* ===========================
 * 公告列表页样式
 * =========================== */

/* 页面内边距 */
.page {
  padding: 20rpx;
}

/* 页面标题区 */
.section-header {
  padding: 20rpx 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

/* 公告列表 */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单条公告 */
.news-item {
  display: flex;
  padding: 16rpx;
}

/* 公告封面 */
.news-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 公告信息区：纵向排列，上下两端对齐 */
.news-info {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex: 1;
}

/* 公告标题：加粗 */
.news-title {
  font-size: 28rpx;
  color: #e0e0e0;
  font-weight: bold;
  line-height: 1.3;
}

/* 摘要：最多 2 行截断 */
.news-summary {
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}


<view class="page">
  
  <view class="section-header">
    <text class="section-title">全部公告</text>
  </view>

  
  <view class="loading-view" wx:if="{{ loading }}">
    <text class="text-muted">加载中...</text>
  </view>

  
  <view class="news-list" wx:else>
    <block wx:for="{{ newsList }}" wx:key="_id">
      
      <view class="news-item card card-touch" bindtap="goToDetail" data-id="{{ item._id }}">
        <image src="{{ item.coverUrl }}" class="news-cover" mode="aspectFill" wx:if="{{ item.coverUrl }}" />
        <view class="news-info">
          <text class="news-title">{{ item.title }}</text>      
          <text class="news-summary text-muted">{{ item.summary }}</text> 
          <text class="text-muted" style="font-size:22rpx;">{{ item.createTime }}</text> 
        </view>
      </view>
    </block>
    
    <view class="empty-view" wx:if="{{ newsList.length === 0 }}">
      <text>暂无公告</text>
    </view>
  </view>
</view>

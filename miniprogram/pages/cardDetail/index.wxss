/* ===========================
 * 卡牌详情页样式
 * =========================== */

/* 页面总体布局 */
.page {
  padding: 20rpx;
  padding-bottom: 140rpx;                          /* 底部留足按钮空间 */
}

/* 卡牌图片展示区：大图居中 */
.card-image-box {
  width: 100%;
  height: 500rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #12121f;                             /* 比背景稍亮的深色 */
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;                                /* 裁剪超出部分 */
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 卡牌信息卡片内边距 */
.card-info {
  padding: 24rpx;
}

/* 信息头部：名称 + 稀有度标签，两端对齐 */
.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 卡牌名称：大号白色加粗 */
.card-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

/* 稀有度标签微调 */
.card-rarity {
  font-size: 24rpx !important;
  padding: 6rpx 20rpx;
}

/* 信息行：标签+值，两端对齐，底部有细分割线 */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #222;
}

/* 信息标签：灰色小字 */
.info-label {
  color: #888;
  font-size: 26rpx;
}

/* 信息值：浅色 */
.info-value {
  color: #e0e0e0;
  font-size: 26rpx;
}

/* 攻防数值双栏布局 */
.stats-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

/* 单个数值盒子：各占一半 */
.stat-box {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #12121f;
  text-align: center;
}

/* 数值标签 */
.stat-label {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-bottom: 8rpx;
}

/* 数值：大号加粗 */
.stat-value {
  font-size: 40rpx;
  font-weight: bold;
}

/* 攻击力用红色 */
.stat-value.atk { color: #ff6b6b; }
/* 生命值用绿色 */
.stat-value.hp { color: #4ecdc4; }

/* 描述区块 */
.desc-box {
  margin-top: 20rpx;
}

/* 描述文字：灰色，稍大行距 */
.desc-text {
  color: #bbb;
  font-size: 26rpx;
  line-height: 1.6;
  margin-top: 8rpx;
  display: block;
}

/* 背景故事：更淡的灰色 + 斜体 */
.flavor-text {
  color: #777;
  font-size: 24rpx;
  font-style: italic;
  line-height: 1.6;
  margin-top: 8rpx;
  display: block;
}

/* 固定底部操作区 */
.add-btn-box {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, #0f0f1a 40%);
}

/* 数量选择行 */
.qty-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.qty-label {
  font-size: 26rpx;
  color: #aaa;
  margin-right: 20rpx;
}

/* 数量步进器 */
.qty-stepper {
  display: flex;
  align-items: center;
  background: #1a1a2e;
  border: 1px solid #2a2a4a;
  border-radius: 10rpx;
}

.qty-btn {
  width: 60rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #e6b800;
}

.qty-btn-disabled {
  opacity: 0.3;
}

.qty-value {
  width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

.add-btn-box .btn-primary {
  display: block;
}
